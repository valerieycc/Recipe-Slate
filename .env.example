# Supabase (required for server-side saved & recent recipes and login)
# Create a project at https://supabase.com and run the SQL in supabase/migrations/001_saved_and_recent.sql in the SQL editor.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: for 5 photo imports/month limit (run supabase/migrations/002_photo_import_usage.sql first)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
